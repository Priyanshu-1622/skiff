# =====================================================
# Skiff environment configuration
#
# Copy this file to .env and adjust before running `docker compose up`.
# =====================================================

# REQUIRED: a 32+ character random secret used to sign session cookies.
# Generate with: openssl rand -hex 32
SKIFF_COOKIE_SECRET=

# OPTIONAL: comma-separated list of origins allowed to call the API
# from a browser. Only matters if you proxy the API to a different
# domain than the web UI. Leave blank if you serve everything from
# the same origin (the default with docker-compose).
SKIFF_TRUSTED_ORIGINS=

# Internal — usually no need to change these.
# SKIFF_PORT=8080
# SKIFF_HOST=0.0.0.0
# SKIFF_DATA_DIR=/app/data
